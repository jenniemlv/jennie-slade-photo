# Cloudinary cloud name (required for image delivery)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"

# Replicate API token (used by the What to Wear flat-lay generator)
REPLICATE_API_TOKEN=""

# ── Journal admin (/admin) ───────────────────────────────────────────────────
# Required to use the in-browser post editor at /admin.
# - ADMIN_PASSWORD: the password Jennie types in at /admin/login
# - ADMIN_SECRET:   a random string used to sign the auth cookie (any 32+ char value)
# - GITHUB_TOKEN:   fine-grained PAT with "Contents: read/write" on this repo
# - GITHUB_OWNER:   GitHub owner of the repo (default: jenniemlv)
# - GITHUB_REPO:    repo name (default: jennie-slade-photo)
# - GITHUB_BRANCH:  branch the admin commits to (default: main)
ADMIN_PASSWORD=""
ADMIN_SECRET=""
GITHUB_TOKEN=""
GITHUB_OWNER="jenniemlv"
GITHUB_REPO="jennie-slade-photo"
GITHUB_BRANCH="main"
